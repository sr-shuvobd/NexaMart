{
  "root": true,
  "extends": ["next", "next/core-web-vitals", "eslint:recommended"],
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module"
  },
  "globals": {
    "React": "writable"
  },
  "rules": {
    "react/no-unescaped-entities": "off",
    "@next/next/no-img-element": "off",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }]
  }
}
